{
  "name": "night-economy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:production": "npm run runtime:verify && npm run check:env && npm run build",
    "cloudflare:config": "node scripts/verify-cloudflare-pages.mjs",
    "check:env": "node scripts/validate-env.mjs",
    "runtime:verify": "node scripts/verify-runtime.mjs",
    "supabase:sql": "node scripts/print-supabase-sql.mjs",
    "supabase:functions": "node scripts/verify-supabase-functions.mjs",
    "preview": "vite preview",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run runtime:verify && npm run lint && npm run test && npm run cloudflare:config && npm run supabase:functions && npm run smoke:preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "@vitejs/plugin-react": "^4.5.2",
    "echarts": "^5.6.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "vitest": "^4.1.9"
  }
}
